# Go build artifacts
/bin/
/forklift
cover.out
*.test

# Local data dir
/.data/

# Local config files (anchored so the internal/config Go package stays tracked)
/config/
!config

# Node / Vite
web/node_modules/
web/.vite/
web/playwright-report/
web/storybook-static/
web/test-results/
/.pnpm-store/

# Embedded UI build output: keep the committed placeholder index.html so the Go
# binary always builds, but ignore compiled assets produced by `make web-build`.
internal/webui/dist/assets/
internal/webui/dist/*.js
internal/webui/dist/*.css

# Packaged Helm charts
*.tgz
