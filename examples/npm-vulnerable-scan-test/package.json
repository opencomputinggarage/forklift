{
  "name": "npm-vulnerable-scan-test",
  "version": "0.1.0",
  "private": true,
  "description": "Intentionally old npm dependencies for forklift artifact scan testing.",
  "scripts": {
    "cache:proxy": "npm install --cache ./.npm-cache --prefer-online --package-lock=false",
    "print:deps": "node -e \"for (const p of ['axios','next','react','react-dom']) console.log(p, require(p + '/package.json').version)\"",
    "test": "npm run print:deps"
  },
  "dependencies": {
    "axios": "0.21.1",
    "next": "12.0.0",
    "react": "17.0.2",
    "react-dom": "17.0.2"
  }
}
